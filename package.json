{
	"name": "todometer",
	"description": "A meter-based to-do list",
	"version": "3.0.0",
	"main": "dist/main/index.cjs",
	"type": "module",
	"author": {
		"name": "Cassidy Williams",
		"email": "hi@cassidoo.co",
		"url": "https://cassidoo.co"
	},
	"homepage": ".",
	"repository": {
		"type": "git",
		"url": "https://github.com/cassidoo/todometer"
	},
	"build": {
		"appId": "co.cassidoo.todometer",
		"productName": "todometer",
		"copyright": "Copyright © 2026 @cassidoo",
		"publish": {
			"provider": "github",
			"owner": "cassidoo",
			"repo": "todometer"
		},
		"afterSign": "scripts/notarize.js",
		"mac": {
			"category": "public.app-category.utilities",
			"icon": "assets/mac/icon.icns",
			"target": [
				"dmg",
				"zip"
			],
			"hardenedRuntime": true,
			"gatekeeperAssess": false,
			"entitlements": "build/entitlements.mac.plist",
			"entitlementsInherit": "build/entitlements.mac.inherit.plist",
			"notarize": false
		},
		"dmg": {
			"sign": false
		},
		"win": {
			"icon": "assets/win/icon.ico",
			"target": [
				"nsis"
			]
		},
		"nsis": {
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"perMachine": false
		},
		"linux": {
			"target": "AppImage",
			"icon": "assets/png/256.png"
		},
		"files": [
			"node_modules/**/*",
			"dist/main/**",
			"dist/preload/**",
			"dist/renderer/**",
			"assets/bloop.mp3",
			"assets/logo.svg",
			"package.json"
		],
		"directories": {
			"buildResources": "assets"
		}
	},
	"scripts": {
		"dev": "node src/scripts/watch.mjs",
		"build": "npm run build:main & npm run build:preload & npm run build:renderer",
		"update-vendors": "cross-env ELECTRON_RUN_AS_NODE=1 electron src/scripts/update-electron-vendors.mjs",
		"build:main": "cd ./src/main && vite build",
		"build:preload": "cd ./src/preload && vite build",
		"build:renderer": "cd ./src/renderer && vite build",
		"test": "cd ./src/renderer && vitest run src",
		"test:watch": "cd ./src/renderer && vitest src",
		"postinstall": "electron-builder install-app-deps && npm run update-vendors",
		"pre-electron-pack": "npm run build",
		"pack": "electron-builder --mac --win --linux",
		"pack:mac": "electron-builder --mac dmg zip",
		"pack:win": "electron-builder --win nsis",
		"pack:linux": "electron-builder --linux AppImage"
	},
	"dependencies": {
		"@dnd-kit/abstract": "^0.4.0",
		"@dnd-kit/dom": "^0.4.0",
		"@dnd-kit/helpers": "^0.4.0",
		"@dnd-kit/react": "^0.4.0",
		"@radix-ui/react-accordion": "^1.2.11",
		"date-fns": "^4.1.0",
		"electron-is-dev": "^3.0.1",
		"electron-store": "^11.0.2",
		"electron-updater": "^6.8.3",
		"prop-types": "^15.8.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4"
	},
	"devDependencies": {
		"@electron/notarize": "^3.1.1",
		"@eslint-react/eslint-plugin": "^3.0.0",
		"@eslint/js": "^10.0.1",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@vitejs/plugin-react": "^5.1.4",
		"cross-env": "^10.1.0",
		"electron": "^40.8.5",
		"electron-builder": "^26.8.1",
		"eslint": "^10.0.2",
		"globals": "^17.4.0",
		"jsdom": "^28.1.0",
		"typescript": "^5.8.3",
		"vite": "^7.3.2",
		"vitest": "^4.0.18"
	}
}
